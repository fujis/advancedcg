/*!
  @file shading.vp
	
  @brief GLSL頂点シェーダ
 
  @author Makoto Fujisawa
  @date 2019
*/
// FILE --shading.vp--
#version 150 core

//-----------------------------------------------------------------------------
// 変数
//-----------------------------------------------------------------------------
uniform mat4 mat_p;	// プロジェクション変換行列
uniform mat4 mat_mv;	// モデルビュー変換行列
in vec4 pos;		// 頂点座標

//-----------------------------------------------------------------------------
// エントリ関数
//-----------------------------------------------------------------------------
void main(void)
{
	// 頂点色と頂点位置
	gl_Position = mat_p*mat_mv*pos;
}
